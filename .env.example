# Slack App Credentials
# Get these from https://api.slack.com/apps > Your App > Basic Information & OAuth
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Supabase (from your DainOS project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Daily Check-in Configuration
# Option 1: Send to a channel (get channel ID by right-clicking channel > View channel details)
MOOD_CHANNEL_ID=C0123456789

# Option 2: Send DMs to specific users (comma-separated Slack user IDs)
# Get user IDs by clicking their profile > More > Copy member ID
MOOD_USER_IDS=U0123456789,U9876543210

# Skip weekends?
SKIP_WEEKENDS=true

# Vercel Cron Secret (protects the cron endpoint from unauthorized access)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# dain-os Monitoring Hub heartbeat ingest. When both are set, the cron
# wraps each run with a started/completed/failed heartbeat so the row on
# https://dainos.app/monitoring/external-crons reflects real run history.
# When unset, the cron still runs normally but goes unmonitored.
# Secret value matches dain-os-kv/MONITORING-HEARTBEAT-SECRET.
MONITORING_HEARTBEAT_URL=https://api.dainos.app/api/v1/monitoring/external-crons/heartbeat
MONITORING_HEARTBEAT_SECRET=
